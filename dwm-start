#!/bin/sh

export PATH="$HOME/.local/bin:$PATH"

# Source system xinitrc scripts
if [ -d /etc/X11/xinit/xinitrc.d ] ; then
    for f in /etc/X11/xinit/xinitrc.d/?*.sh ; do
        [ -x "$f" ] && . "$f"
    done
    unset f
fi

lxpolkit &
fcitx5 -d
dmenu-clipd &
dunst &

# Battery monitor (30 second tick)
while true; do
    battery-notify
    sleep 30
done &

# Start status bar
while true; do
    slstatus
    sleep 1
done &

feh --no-fehbg --bg-fill ~/wallpapers/sushi_original.png &
exec dwm
